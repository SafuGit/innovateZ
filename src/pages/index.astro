---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Home/Hero.astro";
import Products from "../components/Home/Products.astro";
import Services from "../components/Home/Services.astro";
import CTA from "../components/Home/CTA.astro";

const title = "InnovateZ | Build Scalable Digital Products";
const description = "InnovateZ builds scalable, high-performance digital products with modern engineering. Expert in strategy, design, and cloud-native development.";
const keywords = "digital products, scalable software, engineering, cloud-native, custom development, tech strategy";
---

<BaseLayout 
  {title}
  {description}
  {keywords}
  ogType="website"
>
	<Hero />
	<Products />
	<Services />
  <CTA />
</BaseLayout>
