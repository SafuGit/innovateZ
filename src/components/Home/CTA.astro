<section
	class="py-24 px-margin-mobile md:px-margin-desktop mt-16 border-t border-white/5 bg-surface-container-lowest"
>
	<div class="max-w-3xl mx-auto text-center flex flex-col items-center">
		<h2 class="font-headline-lg text-headline-lg text-on-background mb-4">
			Ready to Innovate?
		</h2>
		<p class="font-body-md text-body-md text-on-surface-variant mb-10">
			Let's discuss your project requirements and architect a solution tailored
			to your goals.
		</p>
		<div
			class="w-full glass-panel p-8 rounded-xl text-left border border-white/10"
		>
			<form class="space-y-6">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div>
						<label
							class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider"
							>Name</label
						>
						<input
							class="w-full bg-[#080808] border border-white/10 text-on-background rounded-DEFAULT p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/50 transition-colors font-label-sm placeholder-surface-variant"
							placeholder="John Doe"
							type="text"
						/>
					</div>
					<div>
						<label
							class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider"
							>Email</label
						>
						<input
							class="w-full bg-[#080808] border border-white/10 text-on-background rounded-DEFAULT p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/50 transition-colors font-label-sm placeholder-surface-variant"
							placeholder="john@example.com"
							type="email"
						/>
					</div>
				</div>
				<div>
					<label
						class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider"
						>Project Details</label
					>
					<textarea
						class="w-full bg-[#080808] border border-white/10 text-on-background rounded-DEFAULT p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/50 transition-colors font-label-sm placeholder-surface-variant resize-none"
						placeholder="Describe your project needs..."
						rows="4"></textarea>
				</div>
				<button
					class="w-full bg-primary text-on-primary font-headline-md text-[20px] font-bold py-4 rounded-DEFAULT hover:shadow-[0_0_20px_rgba(255,233,185,0.4)] transition-all flex items-center justify-center gap-2"
					type="submit"
				>
					Request a Quote <span
						class="material-symbols-outlined text-on-primary"
						>arrow_forward</span
					>
				</button>
			</form>
		</div>
	</div>
</section>