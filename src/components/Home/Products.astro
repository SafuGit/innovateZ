---
const products = [
	{
		icon: "school",
		title: "Smart Coaching System",
		description:
			"Complete AI automation for tuition centers and educators. Streamlines administrative tasks, predicts student performance trajectories, and optimizes curriculum delivery.",
		linkText: "Learn More",
		linkHref: "#",
	},
	{
		icon: "ads_click",
		title: "Smart Digital Marketing",
		description:
			"An AI-powered campaign orchestration tool. It dynamically optimizes ad spend across channels in real-time, utilizing predictive analytics to maximize conversion rates and ROI.",
		linkText: "Learn More",
		linkHref: "#",
	},
];

---

<section
	class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full"
>
	<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
		<div
			class="md:col-span-2 relative overflow-hidden rounded-xl bg-linear-to-br from-[#4a148c] to-[#7b1fa2] p-8 md:p-12 border-none shadow-2xl group"
		>
			<div
				class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl -mr-48 -mt-48 transition-transform group-hover:scale-110 duration-1000"
			>
			</div>
			<div class="relative z-10">
				<span
					class="inline-block px-4 py-1 bg-white/20 backdrop-blur-md rounded-full font-label-sm text-label-sm text-white mb-6 tracking-widest uppercase"
					>Our Flagship Product</span
				>
				<h2 class="font-display-lg text-4xl md:text-5xl text-white mb-6">
					AI-Driven Islamic Matrimony
				</h2>
				<p class="font-body-lg text-white/90 max-w-2xl mb-8">
					A sophisticated matchmaking engine utilizing machine learning to align
					user profiles based on deep-seated values, preferences, and cultural
					compatibility parameters.
				</p>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10 max-w-xl">
					<div class="flex items-center gap-3 text-white/90 font-body-md">
						<span class="material-symbols-outlined text-primary-fixed"
							>check_circle</span
						> Smart Compatibility Scoring
					</div>
					<div class="flex items-center gap-3 text-white/90 font-body-md">
						<span class="material-symbols-outlined text-primary-fixed"
							>check_circle</span
						> Privacy-Centric Engineering
					</div>
					<div class="flex items-center gap-3 text-white/90 font-body-md">
						<span class="material-symbols-outlined text-primary-fixed"
							>check_circle</span
						> Cultural Values Alignment
					</div>
					<div class="flex items-center gap-3 text-white/90 font-body-md">
						<span class="material-symbols-outlined text-primary-fixed"
							>check_circle</span
						> Automated Profile Verification
					</div>
				</div>
				<div class="flex flex-wrap items-center gap-6">
					<button
						class="bg-white text-[#4a148c] font-bold px-8 py-3 rounded-DEFAULT hover:shadow-lg transition-all"
						>Buy Now</button
					>
					<button
						class="border border-white/40 text-white font-bold px-8 py-3 rounded-DEFAULT hover:bg-white/10 transition-all"
						>View Details</button
					>
					<a
						class="text-white font-label-sm text-label-sm underline underline-offset-4 hover:text-primary transition-colors"
						href="#">See Demo</a
					>
				</div>
			</div>
		</div>
		{products.map((product) => (
			<div
				class="glass-panel rounded-xl p-8 border border-white/10 flex flex-col"
			>
				<div
					class="bg-surface-container p-3 w-fit rounded-lg border border-white/5 mb-6"
				>
					<span class="material-symbols-outlined text-primary text-3xl"
						>{product.icon}</span
					>
				</div>
				<h3 class="font-headline-md text-on-background mb-4">{product.title}</h3>
				<p class="font-body-md text-on-surface-variant mb-6 grow">
					{product.description}
				</p>
				<a
					class="text-primary font-label-sm flex items-center gap-2 group"
					href={product.linkHref}
					>{product.linkText} <span
						class="material-symbols-outlined group-hover:translate-x-1 transition-transform"
						>arrow_forward</span
					></a
				>
			</div>
		))}
	</div>
</section>
