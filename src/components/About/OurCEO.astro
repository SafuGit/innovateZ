---
import { Image } from 'astro:assets';
import safwanPortrait from '../../assets/safwan.jpeg';
---

<section class="growtive bg-grid-pattern py-20 md:py-30">
	<div
		class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative"
	>
		<!-- Large Decorative Number Background -->
		<div
			class="absolute top-0 left-0 -translate-y-1/4 -translate-x-1/4 pointer-events-none select-none z-0"
		>
			<span
				class="font-display-lg text-[200px] md:text-[400px] leading-none font-bold text-outline-gold"
				>15</span
			>
		</div>
		<div
			class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-center relative z-10 p-8"
		>
			<!-- Left Content: Asymmetrical Text Block -->
			<!-- Left Content -->
			<div
				class="order-2 lg:order-1 lg:col-span-5 lg:col-start-1 flex flex-col items-start gap-8"
			>
				<!-- Label -->
				<div
					class="inline-flex items-center gap-2 px-4 py-2 bg-surface-container-high border border-outline/20 rounded-full"
				>
					<span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
					<span
						class="font-label-sm text-label-sm text-primary tracking-widest uppercase"
						>Gen-Z Visionary</span
					>
				</div>
				<!-- Headlines -->
				<div class="flex flex-col gap-4">
					<h2
						class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface"
					>
						Safwan Sadid
					</h2>
					<h3 class="font-headline-md text-headline-md text-surface-tint">
						Architecting the Next Era of IT.
					</h3>
				</div>
				<!-- Body Content -->
				<div
					class="bg-[#1A1A1A] border border-white/5 p-6 rounded-lg relative overflow-hidden group"
				>
					<!-- Subtle Gold Glow on Hover -->
					<div
						class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
					>
					</div>
					<p
						class="font-body-lg text-body-lg text-on-surface-variant relative z-10"
					>
						Safwan leads InnovateZ with a fast-moving, practical approach to building products. Focused on clean execution and constant improvement, he builds SaaS tools that solve real problems and stay ahead of what users need.
					</p>
				</div>
				<div
					class="bg-[#1A1A1A] border border-white/5 p-6 rounded-lg relative overflow-hidden group w-full lg:w-4/5 lg:self-end"
				>
					<p
						class="font-body-md text-body-md text-on-surface-variant relative z-10"
					>
						“We don't just adapt to the future, we build the systems that shape it. Our focus is creating fast, reliable products that keep up with real-world needs.”
					</p>
				</div>
				<!-- Action -->
				<button
					class="bg-transparent border border-primary text-primary px-8 py-3 font-label-sm text-label-sm hover:bg-primary/10 transition-colors rounded-DEFAULT flex items-center gap-2 mt-4"
				>
					Read Full Bio
					<span
						class="material-symbols-outlined"
						style="font-variation-settings: 'FILL' 0;">arrow_forward</span
					>
				</button>
			</div>
			<!-- Right Content: Tall Conceptual Image Container -->
			<!-- Right Content -->
			<div
				class="order-1 lg:order-2 lg:col-span-6 lg:col-start-7 h-80 md:h-150 w-full mb-10 lg:mb-0 lg:mt-0"
			>
				<!-- Tech Frame Overlay -->
				<div
					class="absolute inset-0 border border-white/10 z-20 pointer-events-none rounded-xl"
				>
				</div>
				<div
					class="absolute top-0 left-0 w-8 h-8 border-t border-l border-primary z-20 pointer-events-none rounded-tl-xl"
				>
				</div>
				<div
					class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-primary z-20 pointer-events-none rounded-br-xl"
				>
				</div>
				<!-- Decorative Elements -->
				<div class="absolute -right-4 top-1/4 h-32 w-px bg-primary/30 z-20">
				</div>
				<div class="absolute -left-4 bottom-1/4 h-32 w-px bg-primary/30 z-20">
				</div>
				<!-- Image Container -->
				<div
					class="w-full h-full relative overflow-hidden rounded-xl bg-surface-container-low group"
				>
					<!-- Abstract Conceptual Image -->
					<Image
						src={safwanPortrait}
						alt="Safwan Sadid"
						width={1200}
						height={1599}
						loading="lazy"
						decoding="async"
						class="object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-700 opacity-80 group-hover:opacity-100 scale-105 group-hover:scale-100"
					/>
					<!-- Overlay Gradient for Depth -->
					<div
						class="absolute inset-0 bg-linear-to-t from-surface via-transparent to-transparent opacity-90"
					>
					</div>
					<div class="absolute inset-0 bg-primary/5 mix-blend-overlay"></div>
				</div>
			</div>
		</div>
	</div>
</section>
